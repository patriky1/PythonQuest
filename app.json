{
  "expo": {
    "name": "PythonQuest",
    "slug": "pythonquest",
    "icon": "./assets/images/icon.png",
    "scheme": "pythonquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "#F6F6F6",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pythonquest.app"
    },
    "android": {
      "package": "com.pythonquest.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "transparent"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
          
        }
      ],
      "expo-image",
        [
    "expo-navigation-bar",
    {
      "visibility": "hidden",
      "barStyle": "light",
      "enforceContrast": false
    }
  ],
      "expo-video"
    ],
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "extra": {
      "eas": {
        "projectId": "bd03f366-7306-40bc-962f-186732a4e312"
      }
    }
  }
}